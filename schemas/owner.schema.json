{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/numtip/mjudrp/schemas/owner.schema.json",
  "title": "Document Owner",
  "description": "Schema for a document owner or responsible party in the MJU-DRP registry.",
  "type": "object",
  "required": ["id", "name", "email"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique owner identifier"
    },
    "name": {
      "type": "string",
      "description": "Full name of the owner (person or department)"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "department": {
      "type": "string",
      "description": "Department or faculty"
    },
    "role": {
      "type": "string",
      "description": "Role or position"
    },
    "phone": {
      "type": "string",
      "description": "Contact phone number"
    }
  }
}
