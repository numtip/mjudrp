{
  "library_name": "DRP Working Area",
  "description": "In-progress documents, drafts, collaborative workspace before formal upload",
  "versioning": {
    "enabled": true,
    "major_versions": true,
    "minor_versions": true,
    "max_major_versions": 50
  },
  "approval": {
    "content_approval_required": false
  },
  "default_metadata": {
    "Visibility": "internal"
  },
