{
  "environment": "development",
  "description": "Local development environment for MJU-DRP",
  "status": "READY",

  "git": {
    "repository": "https://github.com/numtip/mjudrp",
    "branch": "main",
    "last_tag": "platform-v1.0"
  },

  "node": {
    "version_required": ">=18.0.0",
    "package_manager": "npm",
    "dependencies": ["ajv@^8.20.0", "ajv-formats@^3.0.1", "minisearch@^7.2.0"]
  },

  "scripts": {
    "validate": "node scripts/validate-registry.mjs",
    "generate": "node scripts/generate-search-index.mjs",
    "test": "npm test",
    "release": "node scripts/release.mjs",
    "validate-provisioning": "node scripts/validate-provisioning.mjs",
    "validate-deployment": "node scripts/validate-deployment.mjs",
    "validate-package": "node scripts/validate-package.mjs",
    "pilot:import": "node scripts/import-pilot-metadata.mjs",
    "pilot:validate": "node scripts/validate-pilot.mjs"
  },

  "quality_gates": [
    "node scripts/validate-registry.mjs",
    "node scripts/validate-provisioning.mjs",
    "node scripts/validate-deployment.mjs",
    "node scripts/validate-package.mjs",
    "npm test"
  ],

  "sharepoint_access": {
    "type": "none",
    "notes": "Development environment does not require SharePoint access. All operations work with git-committed JSON."
  },

  "notes": [
    "No SharePoint access required for development",
    "All registry data is git-committed JSON",
    "Run validate-registry before committing changes",
    "Run release pipeline before tagging releases"
  ]
}
