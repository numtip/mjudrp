{
  "name": "mjudrp",
  "version": "1.0.0",
  "description": "**A shared document infrastructure layer for Maejo University projects.**",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
